// prisma/zoning/schema.prisma
// Zoning schema placeholder — reserved for future zoning data integration
// NOTE: No url property per Prisma 7.x requirement. Connection URL passed via prisma.config.ts

generator client {
  provider = "prisma-client-js"
  output   = "../../lib/generated/zoning"
}

datasource db {
  provider = "sqlite"
}

// Placeholder model — extend as needed for zoning features
model ZoningRecord {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  label     String
  data      String
}
